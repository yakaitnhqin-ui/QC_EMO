# Ignore everything by default
*

# Allow directories to be traversed (needed for subdirectory tracking)
!*/

# Track root-level markdown files
!/*.md
!/.gitignore

# Track Claude memory files (for WFH context sync)
!/.claude/
!/.claude/projects/
!/.claude/projects/C--Users-nhu-huynh/
!/.claude/projects/C--Users-nhu-huynh/memory/
!/.claude/projects/C--Users-nhu-huynh/memory/*.md

# Explicitly block large/system directories even if matched above
AppData/**
.antigravity/**
.antigravity-ide/**
.gemini/**
.cache/**
.cursor/**
.copilot/**
.vscode/**
.vscode-shared/**
Downloads/**
Documents/**
Desktop/**
3D Objects/**
